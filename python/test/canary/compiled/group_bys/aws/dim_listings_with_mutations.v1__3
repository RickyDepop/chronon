        "query": {
          "selects": {
            "brief_description": "brief_description",
            "currency": "currency",
            "headline": "headline",
            "inventory_count": "inventory_count",
            "is_active": "is_active",
            "is_expensive": "IF(price_cents > 10000, 1, 0)",
            "is_in_stock": "IF(inventory_count > 0, 1, 0)",
